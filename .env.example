# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transport_dashboard?schema=public"

# Auth
AUTH_ENABLED=false
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
DEMO_USER_EMAIL="demo@example.com"
DEMO_USER_PASSWORD="demo123"

# Maps (optional)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Sentry (optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Motive API
MOTIVE_ENABLED=false
MOTIVE_BASE_URL="https://api.gomotive.com"
MOTIVE_API_KEY=""
MOTIVE_SYNC_LOOKBACK_DAYS=90
MOTIVE_PAGE_SIZE=100
